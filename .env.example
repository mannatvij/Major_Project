# Smart Healthcare — environment variable template
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# Spring Boot reads these via ${VAR_NAME} placeholders in application.properties
# (the spring-dotenv dependency in pom.xml loads `.env` at startup).

# JWT signing secret — must be at least 256 bits (64 hex chars).
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000

# SMTP credentials — Mailtrap sandbox or Gmail App Password.
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# Razorpay test-mode credentials (razorpay.com → Settings → API Keys).
# Keep RAZORPAY_ENABLED=false to demo without a real Razorpay account
# (signature verification is skipped and payments are auto-marked PAID).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_ENABLED=false

# Python ML service base URL.
ML_SERVICE_ENABLED=true
